{
  "name": "voice-first-sfu-project",
  "private": true,
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "docs:dev": "npm --prefix app run docs:dev",
    "docs:build": "npm --prefix app run docs:build",
    "docs:preview": "npm --prefix app run docs:preview",
    "format": "prettier --write . && gofmt -w backend",
    "format:check": "prettier --check .",
    "lint": "npm --prefix app run lint -w webapp && cd backend && go test ./...",
    "test:web": "npm --prefix web run test",
    "test:backend": "cd backend && go test ./...",
    "test": "npm run test:web && npm run test:backend"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
